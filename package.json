{
  "name": "vscicons",
  "displayName": "Icons – Maintained",
  "description": "Beautiful file and folder icons for Visual Studio Code",
  "version": "1.1.13",
  "publisher": "yusifaliyevpro",
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.60.0"
  },
  "activationEvents": [
    "onIdentity:identity"
  ],
  "scripts": {
    "build": "tsc && node ./out/extension.js",
    "package": "vsce package",
    "check": "node --no-warnings scripts/pre-check.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "generate": "node --no-warnings folder-icon-maker/generate.ts",
    "sort-icons": "node --no-warnings scripts/sort-icons.ts",
    "build:vsix": "pnpm build && pnpm package"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "contributes": {
    "iconThemes": [
      {
        "id": "icons",
        "label": "Icons",
        "path": "./icons.json"
      }
    ]
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#45403d",
    "theme": "dark"
  },
  "keywords": [
    "icons",
    "theme",
    "icon-theme",
    "file-icons",
    "folder-icons",
    "vscode-icons",
    "material-icons"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yusifaliyevpro/vscode-icons"
  },
  "author": {
    "email": "yusifaliyevpro@gmail.com",
    "name": "Yusif Aliyev"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yusifaliyevpro/vscode-icons/issues"
  },
  "homepage": "https://github.com/yusifaliyevpro/vscode-icons#readme",
  "devDependencies": {
    "@types/node": "24.12.4",
    "@types/vscode": "1.60.0",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "@vscode/vsce": "3.9.2",
    "eslint": "9.39.4",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  }
}
